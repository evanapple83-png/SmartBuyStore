# ============================================================
# Smart Buy Store — environment variabelen
# Kopieer naar .env.local voor lokale dev, vul in op Vercel voor productie.
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# Te vinden in Supabase Studio → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<jouw-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # alleen server-side, nooit in frontend

# ─── Mollie (komt in FASE 7) ────────────────────────────────
# MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── E-mail provider (komt in FASE 9) ───────────────────────
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx
# MAIL_FROM_NAME=Smart Buy Store
# MAIL_FROM_ADDRESS=noreply@smartbuystore.nl
# MAIL_REPLY_TO=info@smartbuystore.nl
#
# Of generieke SMTP:
# MAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ─── Site ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # in prod: https://smartbuystore.nl
